# Local SQLite (dev). One database for everything (auth + app data).
DATABASE_URL=file:./data/local.db

# Turso (production / optional local parity)
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=

# Auth.js — required in production
AUTH_SECRET=generate-with-openssl-rand-base64-32
# Optional in development: defaults to http://127.0.0.1:3000 (see src/lib/app-origin-defaults.ts).
# Set explicitly if you use http://localhost:3000 in the desktop browser only.
# AUTH_URL=http://localhost:3000

# Public URL for MCP / API (same origin as app). Same dev default as AUTH_URL when unset.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# MCP server (mcp-server/) — point at your running app
# WORKOUT_APP_BASE_URL=http://localhost:3000
# WORKOUT_APP_TOKEN=tlog_...   # create in app → Settings

# AI Coach (Claude via Vercel AI SDK) — optional; /app/coach returns 503 if unset
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_QUICK_MODEL=claude-3-5-haiku-20241022   # optional; quick reply chips after each coach turn
# COACH_AI_DEBUG=true   # token usage on replies + composer “Context” preview (POST /api/coach/context-preview) (also: 1, yes, on)
# NEXT_PUBLIC_COACH_AI_DEBUG=true   # optional; show composer debug row before first reply (match COACH_AI_DEBUG)

# AWS deploy: use `npx sst secret set ...` for TursoDatabaseUrl, TursoAuthToken,
# AuthSecret, AuthUrl, AnthropicApiKey (→ ANTHROPIC_API_KEY) for prod — see sst.config.ts / deploy workflow.

# Capacitor Android — URL loaded in the WebView (see docs/capacitor-android.md).
# Production: https URL must match AUTH_URL / NEXT_PUBLIC_APP_URL for NextAuth.
#
# Local dev — pick ONE origin and use it for all three (must match exactly):
#
# (A) WSL + emulator on Windows (recommended): 127.0.0.1 + adb reverse
#     Run: npm run dev:android && npm run android:adb-reverse && npm run android:sync
#     CAP_SERVER_URL=http://127.0.0.1:3000
#     AUTH_URL=http://127.0.0.1:3000
#     NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
#
# (B) Next.js on Windows (not WSL) + emulator: special IP 10.0.2.2
#     Run: npm run dev:android
#     CAP_SERVER_URL=http://10.0.2.2:3000
#     AUTH_URL=http://10.0.2.2:3000
#     NEXT_PUBLIC_APP_URL=http://10.0.2.2:3000
#
# (C) Physical phone on same Wi-Fi: your PC LAN IP (not 127.0.0.1 / not 10.0.2.2)
#     CAP_SERVER_URL=http://192.168.x.x:3000
#     AUTH_URL=http://192.168.x.x:3000
#     NEXT_PUBLIC_APP_URL=http://192.168.x.x:3000
#
# CAP_SERVER_URL=http://127.0.0.1:3000
